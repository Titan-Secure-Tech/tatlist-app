{
  "name": "tatlist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 7500",
    "build": "next build",
    "type-check": "tsc --noEmit",
    "start": "next start -p 7500",
    "lint": "next lint",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\"",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:seed": "tsx supabase/seed.ts",
    "db:migrate": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "make-admin": "tsx supabase/make-admin.ts",
    "scrape:ids": "tsx scripts/scrape-lucky-ids.ts",
    "scrape:products": "tsx scripts/fetch-lucky-products.ts",
    "scrape:import": "tsx scripts/import-lucky-to-supabase.ts",
    "scrape:all": "bun run scrape:ids && bun run scrape:products && bun run scrape:import",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e/",
    "import:production": "tsx scripts/import-to-production.ts",
    "test:production": "vitest run tests/e2e/production-verify.test.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@mendable/firecrawl-js": "^3.2.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@stripe/stripe-js": "^7.9.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.52.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/pg": "^8.15.5",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.514.0",
    "next": "15.3.3",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "square": "^43.0.2",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.3.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@happy-dom/global-registrator": "^18.0.1",
    "@jest/globals": "^30.1.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^17.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.1",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "puppeteer": "^24.15.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
