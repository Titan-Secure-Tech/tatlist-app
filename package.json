{
  "name": "tatlist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 7500",
    "build": "next build",
    "start": "next start -p 7500",
    "lint": "next lint",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\"",
    "dev:bun": "bun run dev",
    "build:bun": "bun run build",
    "start:bun": "bun run start",
    "supabase:start": "bunx supabase start",
    "supabase:stop": "bunx supabase stop",
    "supabase:seed": "bun run supabase/seed.ts",
    "db:migrate": "bunx supabase db push",
    "db:reset": "bunx supabase db reset",
    "make-admin": "bun run supabase/make-admin.ts",
    "scrape:ids": "bun run scripts/scrape-lucky-ids.ts",
    "scrape:products": "bun run scripts/fetch-lucky-products.ts",
    "scrape:import": "bun run scripts/import-lucky-to-supabase.ts",
    "scrape:all": "bun run scrape:ids && bun run scrape:products && bun run scrape:import",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "vitest run tests/e2e/",
    "import:production": "bun run scripts/import-to-production.ts",
    "test:production": "vitest run tests/e2e/production-verify.test.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@mendable/firecrawl-js": "^3.2.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@stripe/stripe-js": "^7.9.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.52.1",
    "@types/pg": "^8.15.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "lucide-react": "^0.514.0",
    "next": "15.3.3",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.6",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.3.0",
    "use-shopping-cart": "^3.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@jest/globals": "^30.1.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.1",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "puppeteer": "^24.15.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
