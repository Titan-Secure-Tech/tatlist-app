{
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/sync-customers",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/alerts/monitor",
      "schedule": "* * * * *",
      "method": "POST"
    }
  ]
}
