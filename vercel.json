{
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.tatlist.com"
        }
      ],
      "destination": "https://tatlist.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-customers",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/alerts/monitor",
      "schedule": "* * * * *"
    }
  ]
}
