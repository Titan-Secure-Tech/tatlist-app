# NEXT_PUBLIC_SITE_URL=https://your-production-url.com  # Production

# Square Payment Configuration (Sandbox/Development)
NEXT_PUBLIC_SQUARE_SANDBOX_APPLICATION_ID=your-square-sandbox-app-id
NEXT_PUBLIC_SQUARE_SANDBOX_LOCATION_ID=your-square-sandbox-location-id
SQUARE_SANDBOX_ACCESS_TOKEN=your-square-sandbox-access-token
SQUARE_SANDBOX_LOCATION_ID=your-square-sandbox-location-id

# Square Payment Configuration (Production)
NEXT_PUBLIC_SQUARE_PRODUCTION_APPLICATION_ID=your-square-production-app-id
NEXT_PUBLIC_SQUARE_PRODUCTION_LOCATION_ID=your-square-production-location-id
SQUARE_PRODUCTION_ACCESS_TOKEN=your-square-production-access-token
SQUARE_PRODUCTION_LOCATION_ID=your-square-production-location-id

# FireCrawl API (for Lucky Supply scraping)
